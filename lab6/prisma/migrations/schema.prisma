datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String   @unique
  orders    Order[]
}

model Order {
  id         Int      @id @default(autoincrement())
  customer   Customer @relationship(fields: [customerId], references: [id])
  customerId Int
  amount     Float
}
